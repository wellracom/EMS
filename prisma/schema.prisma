generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  email         String?
  name          String
  role          Role
   refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}




model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  admin
  operator
  supervisor
  maintanace
}

/*
  Ini model untuk konfigurasi
  Modbus TCP 
*/
model Mtcplist {
  id         String   @id @default(cuid())
  name       String   @unique
  ip         String
  port       Int
  unitId     Int
  timeout    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mtcpaddrs  Mtcpaddress[]
   @@unique([ip, port, unitId]) 
}

model Mtcpaddress {
  id           String   @id @default(cuid())
  mtcpId       String
  address      Int
  functioncode MtcpFC
  typedata     Mtcptypedata
  canread      Boolean
  canwrite     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mtcp         Mtcplist @relation(fields: [mtcpId], references: [id], onDelete: Cascade)
  tags         Tag[]

 
}

enum Mtcptypedata {
  INT16_SIGNED
  INT16_UNSIGNED
  INT32_BIG_ENDIAN
  INT32_LITTLE_ENDIAN
  FLOAT32_ABCD
  FLOAT32_BADC
  FLOAT32_CDAB
  FLOAT32_DCBA
  DOUBLE64
  BOOLEAN
  ASCII
  BCD
}

enum MtcpFC {
  FC1
  FC2
  FC3
  FC4
}

/*
  Ini model untuk konfigurasi TAG 
*/
model Tag {
  id              String   @id @default(cuid())
  mtcpaddressId   String?
  name            String   @unique

  offset          Decimal? @db.Decimal(10, 3)
  gain            Decimal? @db.Decimal(10, 3)
  unit            String?

  lowlow          Decimal? @db.Decimal(10, 3)
  low             Decimal? @db.Decimal(10, 3)
  high            Decimal? @db.Decimal(10, 3)
  highhigh        Decimal? @db.Decimal(10, 3)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mtcpaddress     Mtcpaddress? @relation(fields: [mtcpaddressId], references: [id], onDelete: Cascade)
}